{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information"
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "/app/logs/log-.txt",
          "rollingInterval": "Day"
        }
      }
    ]
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=<Host_Name>;Port=<Port>;Database=UserManagementDB;Username=<User_Name>;Password=<Db_Password>;Password=<your_password>;SSL Mode=Require;Trust Server Certificate=true;"
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Key": "<Key_Name>",
    "Issuer": "<Issuer>",
    "Audience": "<Audience>",
    "ExpiryMinutes": 30
  }
}
